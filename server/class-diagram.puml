@startuml MindHaven
title MindHaven Full System Architecture (Updated Features)

skinparam packageStyle rectangle
skinparam class {
  BackgroundColor Snow
  BorderColor Black
  ArrowColor Black
}

' Force vertical stacking
left to right direction
skinparam package {
  BorderColor black
}

' Frontend = widest
package "Frontend (React)" as FE {
  class LoginPage
  class RegisterPage
  class AccountProfilePage
  class AccountLayoutPage
  class JournalCreatePage
  class JournalDetailPage
  class JournalEditPage
  class JournalListPage
  class JournalStatsPage
  class JournalCalendarPage
  class BuddyPage
  class BuddyProfilePage
  class SOSPage
  class AIChatPage
}

' Backend = medium width
package "Backend (Node/Express)" as BE {
  
  ' AUTH
  class AuthController {
    +registerUser(req, res)
    +loginUser(req, res)
    +resetPassword(req, res)
  }

  class JWTService {
    +generateToken(user)
    +verifyToken(token)
  }

  ' USER
  class User {
    -id : int
    -username : string
    -email : string
    -password : string
    -bio : string
    -profile_picture : string
    -country : string
    -gender : string
  }

  class UserController {
    +getProfile(req, res)
    +updateProfile(req, res)
    +uploadProfilePicture(req, res)
    +deleteAccount(req, res)
  }

  ' JOURNAL
  class JournalController {
    +createJournal(req, res)
    +updateJournal(req, res)
    +deleteJournal(req, res)
    +listJournals(req, res)
    +filterByTag(req, res)
    +sortByDate(req, res)
  }

  class Journal {
    -id : int
    -user_id : int
    -title : string
    -content : text
    -tags : string[]
    -created_at : date
  }

  class Tag {
    -id : int
    -name : string
  }

  ' BUDDY
  class BuddyController {
    +connectBuddy(req, res)
    +removeBuddy(req, res)
    +updateStreak(req, res)
    +listBuddies(req, res)
  }

  class Buddy {
    -id : int
    -user_id : int
    -buddy_id : int
    -streak : int
  }

  ' AI
  class AIController {
    +chatWithAI(req, res)
    +getSuggestions(req, res)
  }

  ' SOS
  class SOSController {
    +getEmergencyList(req, res)
    +getHotlines(req, res)
    +getYouTubeResources(req, res)
  }

  ' DATABASE WRAPPER
  class Database {
    +connect()
    +query(sql, params)
    +close()
  }
}

' Database = smallest width, placed at bottom
package "Database (MySQL)" as DB {
  
  class users {
    id : int
    username : string
    email : string
    password : string
    bio : string
    profile_picture : string
    country : string
    gender : string
  }

  class journals {
    id : int
    user_id : int
    title : string
    content : text
    tags : string
    created_at : date
  }

  class buddies {
    id : int
    user_id : int
    buddy_id : int
    streak : int
  }

  class tags {
    id : int
    name : string
  }
}

' Position them vertically with decreasing size
FE -down-> BE
BE -down-> DB


' ===================== CONNECTIONS =====================

' FRONTEND → BACKEND
LoginPage -[#blue]-> AuthController : POST /api/auth/login
RegisterPage -[#blue]-> AuthController : POST /api/auth/register
AccountProfilePage -[#blue]-> UserController : GET /api/user/profile
AccountProfilePage -[#blue]-> UserController : PUT /api/user/profile
AccountProfilePage -[#blue]-> UserController : POST /api/user/profile/upload

JournalCreatePage -[#blue]-> JournalController : POST /api/journal/create
JournalListPage -[#blue]-> JournalController : GET /api/journal/list
JournalDetailPage -[#blue]-> JournalController : GET /api/journal/:id
JournalEditPage -[#blue]-> JournalController : PUT /api/journal/update/:id
JournalListPage -[#blue]-> JournalController : GET /api/journal/filter?tag=
JournalListPage -[#blue]-> JournalController : GET /api/journal/sort?by=date

BuddyPage -[#blue]-> BuddyController : GET /api/buddy/list
BuddyProfilePage -[#blue]-> BuddyController : POST /api/buddy/connect
BuddyProfilePage -[#blue]-> BuddyController : DELETE /api/buddy/remove

SOSPage -[#blue]-> SOSController : GET /api/sos/list
SOSPage -[#blue]-> SOSController : GET /api/sos/hotlines

AIChatPage -[#blue]-> AIController : POST /api/ai/chat

' BACKEND → DATABASE
AuthController --> User
AuthController --> JWTService
UserController --> User
JournalController --> Journal
JournalController --> Tag
BuddyController --> Buddy

AIController --> Database
SOSController --> Database

User --> users
Journal --> journals
Buddy --> buddies
Tag --> tags

@enduml
